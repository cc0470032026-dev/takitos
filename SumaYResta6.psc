Algoritmo SumaYResta6
	Definir numx, numy, suma, resta Como Real
	
	Escribir "Introduce el primer número:"
	Leer numx
	Escribir "Introduce el segundo número:"
	Leer numy
	
	suma <- numx + numy
	resta <- numx- numy
	
	Escribir "La suma de ", numx, " + ", numy, " es: ", suma
	Escribir "La resta de ", numx, " - ", numy, " es: ", resta
FinAlgoritmo